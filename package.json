{
  "name": "docs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "prebuild": "tsx scripts/generate-shared-config.ts",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "lint:md": "markdownlint-cli2 \"README.md\" \"CONTRIBUTING.md\" \"docs/**/*.{md,mdx}\" \"src/**/*.{md,mdx}\"",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "analyze": "ANALYZE=true npm run build",
    "export": "next export",
    "clean": "rm -rf .next out",
    "test": "vitest run",
    "test:watch": "vitest",
    "audit": "npm audit --audit-level=moderate",
    "update-deps": "npm update && npm audit fix"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.6",
    "@react-three/fiber": "^9.4.0",
    "@theguild/remark-mermaid": "^0.3.0",
    "dotenv": "^17.2.3",
    "framer-motion": "^12.23.22",
    "lucide-react": "^0.545.0",
    "mermaid": "^11.15.0",
    "next": "^15.5.18",
    "next-intl": "^4.9.2",
    "next-themes": "^0.4.6",
    "nextra": "^4.6.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.41",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/three": "^0.180.0",
    "eslint": "^9",
    "eslint-config-next": "15.3.6",
    "markdownlint": "^0.39.0",
    "markdownlint-cli2": "^0.22.1",
    "prettier": "^3.6.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.7",
    "wink-eng-lite-web-model": "^1.8.1",
    "wink-nlp": "^2.4.0"
  },
  "overrides": {
    "@xmldom/xmldom": ">=0.9.10",
    "axios": ">=1.16.0",
    "brace-expansion": ">=5.0.6",
    "dompurify": ">=3.4.5",
    "follow-redirects": ">=1.16.0",
    "js-yaml": ">=4.1.1",
    "markdown-it": ">=14.1.1",
    "postcss": ">=8.5.10",
    "uuid": ">=11.1.1"
  }
}
